{
  "expo": {
    "name": "Foot Is Life",
    "slug": "foot-is-life",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "footislife",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B5E20"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.footislife.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Foot Is Life a besoin d'accéder à ta caméra pour filmer ta frappe.",
        "NSMicrophoneUsageDescription": "Foot Is Life a besoin du micro pour enregistrer le son de ta frappe.",
        "NSPhotoLibraryUsageDescription": "Foot Is Life a besoin d'accéder à ta photothèque pour importer une vidéo de frappe."
      }
    },
    "android": {
      "package": "com.footislife.app",
      "adaptiveIcon": {
        "backgroundColor": "#1B5E20",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-video",
      [
        "expo-camera",
        {
          "cameraPermission": "Foot Is Life a besoin d'accéder à ta caméra pour filmer ta frappe.",
          "microphonePermission": "Foot Is Life a besoin du micro pour enregistrer le son de ta frappe.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Foot Is Life a besoin d'accéder à ta photothèque pour importer une vidéo de frappe."
        }
      ],
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e94b6d39-af03-4488-9d5b-13564bec6c61"
      }
    },
    "owner": "taboutmhamed"
  }
}
